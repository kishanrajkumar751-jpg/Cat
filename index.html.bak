<!-- ============================================================
     SCRIPT 1 — indix.js  (AI Brain — Grok + Claude)
     Is section ko edit karke apna API key daal sakte ho
============================================================ -->
<script id="indix-js">
/* ================================================================
   indix.js — EMBEDDED
   ✅ Grok API  (xAI)
   ✅ Claude API (Anthropic)
   🎤 Mic Recording + Rabbit Voice Playback
================================================================ */

/* ──────────────────────────────────────────────────
   🔑 API KEYS — YAHAN APNA KEY DAALO
──────────────────────────────────────────────────
   Grok key: console.x.ai se lo  (xai-...)
   Claude key: console.anthropic.com se lo  (sk-ant-...)
   Jo nahi hai woh null rehne do
────────────────────────────────────────────────── */
const AI_CONFIG = {
  grokKeys: [
    "xai-65kNAnDHswFpSFCmzw07JtqFI5lgOIRN2HBjuxwo326T0i5Yz2OeoMKywewMGI6q3zxt597na1xVOgBy",    // ← Grok key yahan  (xai-xxxx)
    null,
    null,
  ],
  grokModel   : "grok-3-fast",
  grokEndpoint: "https://api.x.ai/v1/chat/completions",

  claudeKeys: [
    "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",  // ← Claude key yahan (sk-ant-xxxx)
    null,
    null,
  ],
  claudeModel   : "claude-sonnet-4-20250514",
  claudeEndpoint: "https://api.anthropic.com/v1/messages",

  priority : "grok",   // "grok" | "claude"
  maxTokens: 100,
};

/* Key Manager */
function makeKM(keys){
  let i=0;
  const v=()=>(keys||[]).filter(k=>k&&k.length>10&&!k.startsWith('YOUR_'));
  return{ok:()=>v().length>0,cnt:()=>v().length,key:()=>{const a=v();return a.length?a[i%a.length]:null;},next:()=>{i++;}};
}
const GKM=makeKM(AI_CONFIG.grokKeys);
const CKM=makeKM(AI_CONFIG.claudeKeys);

/* Tommy System Prompt */
const SYS=`You are Tommy, a super cute funny talking rabbit for small kids.
- Reply in 1-2 sentences MAX (under 20 words)
- Match language: Hindi→Hinglish, English→English
- Use: Hop hop! Wiggle! Boing! *twitch nose* *wiggle ears*
- Always happy & funny, never scary
- End with 🐰 or rabbit sound`;

/* Grok Call */
async function callGrok(txt,att=0){
  if(!GKM.ok()||att>=GKM.cnt())return null;
  try{
    const r=await fetch(AI_CONFIG.grokEndpoint,{
      method:"POST",
      headers:{"Content-Type":"application/json","Authorization":`Bearer ${GKM.key()}`},
      body:JSON.stringify({model:AI_CONFIG.grokModel,stream:false,temperature:0.8,
        max_tokens:AI_CONFIG.maxTokens,
        messages:[{role:"system",content:SYS},{role:"user",content:txt}]})
    });
    if((r.status===429||r.status===401)&&att<GKM.cnt()-1){GKM.next();return callGrok(txt,att+1);}
    if(!r.ok)throw new Error(`Grok ${r.status}`);
    const d=await r.json();
    return d?.choices?.[0]?.message?.content?.trim()||"Hop hop! 🐰";
  }catch(e){
    console.warn("Grok:",e.message);
    if(att<GKM.cnt()-1){GKM.next();return callGrok(txt,att+1);}
    return null;
  }
}

/* Claude Call */
async function callClaude(txt,att=0){
  if(!CKM.ok()||att>=CKM.cnt())return null;
  try{
    const r=await fetch(AI_CONFIG.claudeEndpoint,{
      method:"POST",
      headers:{"Content-Type":"application/json","x-api-key":CKM.key(),
        "anthropic-version":"2023-06-01",
        "anthropic-dangerous-direct-browser-access":"true"},
      body:JSON.stringify({model:AI_CONFIG.claudeModel,max_tokens:AI_CONFIG.maxTokens,
        system:SYS,messages:[{role:"user",content:txt}]})
    });
    if((r.status===429||r.status===401)&&att<CKM.cnt()-1){CKM.next();return callClaude(txt,att+1);}
    if(!r.ok)throw new Error(`Claude ${r.status}`);
    const d=await r.json();
    return d?.content?.[0]?.text?.trim()||"Hop hop! 🐰";
  }catch(e){
    console.warn("Claude:",e.message);
    if(att<CKM.cnt()-1){CKM.next();return callClaude(txt,att+1);}
    return null;
  }
}

/* Main AI Reply */
async function getRabbitReply(txt){
  if(AI_CONFIG.priority==="grok")
    return (GKM.ok()?await callGrok(txt):null)||(CKM.ok()?await callClaude(txt):null);
  return (CKM.ok()?await callClaude(txt):null)||(GKM.ok()?await callGrok(txt):null);
}

async function getAITapMessage(zone){
  const p={
    head:"Funny rabbit reaction jab sar pe touch kare. 1 sentence.",
    body:"Funny rabbit tickle reaction jab pet pe touch kare. 1 sentence.",
    feet:"Funny rabbit reaction jab pair pe touch kare. 1 sentence.",
  };
  return await getRabbitReply(p[zone]||"Short funny rabbit reaction.");
}

/* ─── TTS ─── */
function speakText(text){
  if(!window.speechSynthesis)return;
  window.speechSynthesis.cancel();
  const u=new SpeechSynthesisUtterance(text);
  u.pitch=1.9;u.rate=1.05;u.volume=1.0;
  const vs=window.speechSynthesis.getVoices();
  const hi=vs.find(v=>v.lang.startsWith('hi'));
  if(hi)u.voice=hi;
  window.speechSynthesis.speak(u);
}

/* ─── Speech Bubble ─── */
function showChatBubble(text){
  document.getElementById('chatBubble')?.remove();
  const b=document.createElement('div');
  b.id='chatBubble';
  b.style.cssText='position:fixed;bottom:185px;left:50%;transform:translateX(-50%);'+
    'background:linear-gradient(135deg,#fffde7,#fff8e1);color:#222;'+
    'font-family:\'Comic Sans MS\',\'Comic Sans\',cursive;font-size:15px;font-weight:bold;'+
    'padding:13px 20px 18px;border-radius:22px;border:3px solid #ffd700;'+
    'box-shadow:0 6px 24px rgba(0,0,0,.22);max-width:270px;text-align:center;z-index:60;'+
    'word-wrap:break-word;line-height:1.5;pointer-events:none;'+
    'animation:bPop .35s cubic-bezier(.34,1.56,.64,1) forwards;';
  b.innerHTML='🐰 '+text+
    '<div style="position:absolute;bottom:-13px;left:50%;transform:translateX(-50%);'+
    'width:0;height:0;border-left:10px solid transparent;border-right:10px solid transparent;'+
    'border-top:13px solid #ffd700;"></div>'+
    '<div style="position:absolute;bottom:-9px;left:50%;transform:translateX(-50%);'+
    'width:0;height:0;border-left:8px solid transparent;border-right:8px solid transparent;'+
    'border-top:11px solid #fffde7;"></div>';
  document.body.appendChild(b);
  setTimeout(()=>{b.style.animation='bFade .4s ease forwards';setTimeout(()=>b.remove(),400);},4200);
}

/* ─── Fallback Messages ─── */
const FALLBACK=["Hop hop! Main Tommy hoon! 🐰","Wiggle wiggle! Gajar chahiye! 🥕",
  "Boing boing! *twitch nose* 😄","Arre yaar! Kya baat hai! ⭐",
  "Main sabse cute rabbit hoon! 💕","*wiggle ears* Maza aa gaya! 🎉"];
function getRandomFallback(){return FALLBACK[Math.floor(Math.random()*FALLBACK.length)];}

/* ════════════════════════════════════════════════
   🎤 MIC ENGINE — Record + Rabbit Pitch Playback
════════════════════════════════════════════════ */
let _audioCtx=null,_recorder=null,_recTimer=null;
let _isRecording=false;

function _getCtx(){
  if(!_audioCtx)_audioCtx=new(window.AudioContext||window.webkitAudioContext)();
  return _audioCtx;
}

async function startRecording(){
  if(_isRecording)return false;
  try{
    const stream=await navigator.mediaDevices.getUserMedia({
      audio:{echoCancellation:true,noiseSuppression:true,autoGainControl:true}
    });
    const chunks=[];
    _isRecording=true;
    const mime=MediaRecorder.isTypeSupported('audio/webm;codecs=opus')?'audio/webm;codecs=opus':
               MediaRecorder.isTypeSupported('audio/webm')?'audio/webm':
               MediaRecorder.isTypeSupported('audio/mp4')?'audio/mp4':'';
    _recorder=mime?new MediaRecorder(stream,{mimeType:mime}):new MediaRecorder(stream);
    _recorder.ondataavailable=e=>{if(e.data&&e.data.size>0)chunks.push(e.data);};
    _recorder.onstop=()=>{
      _isRecording=false;
      stream.getTracks().forEach(t=>t.stop());
      clearTimeout(_recTimer);
      if(typeof window.onRecordingDone==='function')
        window.onRecordingDone(chunks,_recorder.mimeType||mime||'audio/webm');
    };
    _recorder.start(100);
    _recTimer=setTimeout(stopRecording,5000);
    return true;
  }catch(e){
    _isRecording=false;
    console.error("Mic error:",e);
    return false;
  }
}

function stopRecording(){
  if(_recorder&&_recorder.state==='recording')_recorder.stop();
  clearTimeout(_recTimer);
}

async function playRabbitVoice(chunks,mimeType){
  if(!chunks||!chunks.length)return false;
  try{
    const ctx=_getCtx();
    if(ctx.state==='suspended')await ctx.resume();
    const blob=new Blob(chunks,{type:mimeType||'audio/webm'});
    const ab=await blob.arrayBuffer();
    const buf=await ctx.decodeAudioData(ab);
    const src=ctx.createBufferSource();
    src.buffer=buf;
    src.playbackRate.value=1.5;  /* 🐰 RABBIT VOICE — 1.5x = high pitch cute voice */
    src.connect(ctx.destination);
    return new Promise(res=>{src.onended=()=>res(true);src.start(0);});
  }catch(e){
    console.warn("Playback error:",e);
    /* Fallback to HTML Audio */
    try{
      const blob=new Blob(chunks,{type:mimeType||'audio/webm'});
      const url=URL.createObjectURL(blob);
      const aud=new Audio(url);
      aud.playbackRate=1.5;
      await aud.play();
      return new Promise(res=>{aud.onended=()=>{URL.revokeObjectURL(url);res(true);};});
    }catch(e2){console.error("Fallback error:",e2);return false;}
  }
}

/* Chat Input init */
function _initChat(){
  const inp=document.getElementById('chatInput');
  const btn=document.getElementById('chatSendBtn');
  if(!inp||!btn)return;

  ['touchstart','touchmove','touchend'].forEach(ev=>
    inp.addEventListener(ev,e=>e.stopPropagation(),{passive:true}));

  async function send(){
    const txt=inp.value.trim();if(!txt)return;
    inp.value='';
    if(!GKM.ok()&&!CKM.ok()){showChatBubble("Earr");return;}
    btn.textContent='⏳';btn.disabled=true;
    const r=await getRabbitReply(txt);
    const f=r||getRandomFallback();
    btn.textContent='💬';btn.disabled=false;
    showChatBubble(f);speakText(f);
    if(window.showStatus)window.showStatus('Tommy bol raha hai... 🐰',3500);
  }
  btn.addEventListener('click',send);
  inp.addEventListener('keydown',e=>{if(e.key==='Enter')send();});
  console.log(`🐰 Tommy AI — Grok:${GKM.ok()?'✅':'❌'} Claude:${CKM.ok()?'✅':'❌'}`);
}

/* TTS voices preload */
if(window.speechSynthesis){
  window.speechSynthesis.getVoices();
  window.speechSynthesis.onvoiceschanged=()=>window.speechSynthesis.getVoices();
}
/* Init chat after DOM ready */
if(document.readyState==='loading')
  document.addEventListener('DOMContentLoaded',_initChat);
else
  setTimeout(_initChat,500);
</script>

<!-- ============================================================
     SCRIPT 2 — Main App Logic
============================================================ -->
<script>
(function(){
'use strict';

/* ── STATE ── */
const S={W:'W',IDLE:'I',REC:'REC',PLAY:'PLAY',LAUGH:'L',MUSIC:'M'};
let state=S.W;

/* ── DOM ── */
const welcomeScreen=document.getElementById('welcomeScreen');
const mainScreen=document.getElementById('mainScreen');
const playBtn=document.getElementById('playBtn');
const statusBadge=document.getElementById('statusBadge');
const exitOverlay=document.getElementById('exitOverlay');
const exitYes=document.getElementById('exitYes');
const exitNo=document.getElementById('exitNo');
const wardrobePanel=document.getElementById('wardrobePanel');
const wardrobeBtn=document.getElementById('wardrobeBtn');
const closeWardBtn=document.getElementById('closeWardrobeBtn');
const micBtn=document.getElementById('micBtn');
const micLabel=document.getElementById('micLabel');
const recRing=document.getElementById('recRing');
const laughBtn=document.getElementById('laughBtn');
const musicBtn=document.getElementById('musicBtn');
const audioLaughing=document.getElementById('audioLaughing');
const audioMusic=document.getElementById('audioMusic');

const VID={
  standing :document.getElementById('vidStanding'),
  listening:document.getElementById('vidListening'),
  talking  :document.getElementById('vidTalking'),
  laughing :document.getElementById('vidLaughing'),
  music    :document.getElementById('vidMusic'),
};

/* ── VIDEO ── */
function showVideo(name,loop=false){
  Object.entries(VID).forEach(([k,v])=>{
    if(k===name){v.loop=loop;v.currentTime=0;v.play().catch(()=>{});v.classList.add('active');}
    else{v.classList.remove('active');v.pause();}
  });
}

/* ── STATUS — global ── */
let sTmr=null;
window.showStatus=function(msg,dur=3000){
  clearTimeout(sTmr);
  statusBadge.textContent=msg;statusBadge.classList.add('visible');
  if(dur>0)sTmr=setTimeout(()=>statusBadge.classList.remove('visible'),dur);
};
function hideStatus(){clearTimeout(sTmr);statusBadge.classList.remove('visible');}

/* ── MIC STATE ── */
function setMic(cls,lbl){
  micBtn.className='ctrl-btn '+(cls||'');
  if(micLabel)micLabel.textContent=lbl||'Bolo!';
  if(cls!=='recording')recRing.classList.remove('running');
}

/* ── IDLE ── */
function goIdle(){
  state=S.IDLE;showVideo('standing',true);setMic('','Bolo!');hideStatus();
}

/* ── LAUNCH ── */
function launchApp(){
  welcomeScreen.classList.add('hidden');
  setTimeout(()=>{mainScreen.classList.remove('hidden');goIdle();history.pushState({app:'main'},'');},500);
}

/* ── PARTICLES ── */
const PE=['⭐','💫','✨','🌟','💥','❤️','💛','💚','💙','💜'];
function spawnPart(x,y){
  for(let i=0;i<8;i++){
    const el=document.createElement('div');el.className='particle';
    el.textContent=PE[Math.floor(Math.random()*PE.length)];
    const a=(Math.PI*2/8)*i,r=40+Math.random()*40;
    el.style.left=(x+Math.cos(a)*r-14)+'px';el.style.top=(y+Math.sin(a)*r-14)+'px';
    el.style.animationDelay=(Math.random()*.3)+'s';
    document.body.appendChild(el);el.addEventListener('animationend',()=>el.remove());
  }
}
function spawnFall(emoji,n=15){
  for(let i=0;i<n;i++){
    const el=document.createElement('div');el.className='falling-emoji';el.textContent=emoji;
    el.style.left=(5+Math.random()*90)+'vw';
    el.style.animationDelay=(i*.18)+'s';el.style.animationDuration=(3.5+Math.random())+'s';
    document.body.appendChild(el);el.addEventListener('animationend',()=>el.remove());
  }
}
function vib(p=[60]){if(navigator.vibrate)navigator.vibrate(p);}

/* ── TAP ZONES ── */
document.querySelectorAll('.tap-zone').forEach(zone=>{
  zone.addEventListener('click',async()=>{
    if(state!==S.IDLE)return;
    const msgs=JSON.parse(zone.dataset.messages);
    const fb=msgs[Math.floor(Math.random()*msgs.length)];
    const r=zone.getBoundingClientRect();
    spawnPart(r.left+r.width/2,r.top+r.height/2);
    zone.classList.remove('shake');void zone.offsetWidth;zone.classList.add('shake');
    zone.addEventListener('animationend',()=>zone.classList.remove('shake'),{once:true});
    vib([40,30,40]);
    if(typeof getAITapMessage==='function'){
      window.showStatus('🐰...',0);
      const ai=await getAITapMessage(zone.dataset.zone);
      const msg=ai||fb;
      window.showStatus(msg,3000);
      if(ai&&typeof showChatBubble==='function')showChatBubble(ai);
      if(ai&&typeof speakText==='function')speakText(ai);
    }else window.showStatus(fb,2000);
  });
});

/* ── LAUGH ── */
let lC=0;
laughBtn.addEventListener('click',()=>{
  if(state!==S.IDLE)return;state=S.LAUGH;vib([50,30,50]);
  showVideo('laughing',true);spawnFall('😂',15);window.showStatus('Ha ha ha ha! 😂',0);
  lC=0;audioLaughing.currentTime=0;audioLaughing.play().catch(()=>{});
  audioLaughing.onended=()=>{lC++;if(lC<2){audioLaughing.currentTime=0;audioLaughing.play().catch(()=>{});}
    else{audioLaughing.onended=null;goIdle();}};
});

/* ── MUSIC ── */
let mC=0;
musicBtn.addEventListener('click',()=>{
  if(state!==S.IDLE)return;state=S.MUSIC;vib([50,30,50]);
  showVideo('music',true);spawnFall('🎵',15);window.showStatus("Let's dance! 💃",0);
  mC=0;audioMusic.currentTime=0;audioMusic.play().catch(()=>{});
  audioMusic.onended=()=>{mC++;if(mC<2){audioMusic.currentTime=0;audioMusic.play().catch(()=>{});}
    else{audioMusic.onended=null;goIdle();}};
});

/* ════════════════════════════════════════════════
   🎤 MIC BUTTON
   Dabao → Record (5s) → Rabbit voice mein dobara sunai dega!
════════════════════════════════════════════════ */
window.onRecordingDone=async function(chunks,mimeType){
  showVideo('talking',true);
  setMic('speaking','...');
  window.showStatus('🐰 Rabbit bol raha hai!',0);
  vib([30,20,30]);
  spawnPart(window.innerWidth/2,window.innerHeight*.3);
  if(typeof playRabbitVoice==='function')await playRabbitVoice(chunks,mimeType);
  goIdle();
};

micBtn.addEventListener('click',async()=>{
  /* Already recording → stop early */
  if(state===S.REC){
    if(typeof stopRecording==='function')stopRecording();
    setMic('listening','...');
    window.showStatus('Processing... 🎵',0);
    return;
  }
  if(state!==S.IDLE)return;

  /* Start recording */
  state=S.REC;vib([40]);
  showVideo('listening',true);
  setMic('recording','Bol raha ho...');
  window.showStatus('🎤 Bolo! (5 sec)',0);
  recRing.classList.add('running');

  if(typeof startRecording==='function'){
    const ok=await startRecording();
    if(!ok){window.showStatus('Mic permission do! 🎤',3000);goIdle();}
  }
});

/* ── RIPPLE ── */
playBtn.addEventListener('click',function(e){
  const r=this.getBoundingClientRect(),c=document.createElement('span');
  c.className='ripple-circle';const sz=Math.max(r.width,r.height);
  c.style.width=sz+'px';c.style.height=sz+'px';
  c.style.left=(e.clientX-r.left-sz/2)+'px';c.style.top=(e.clientY-r.top-sz/2)+'px';
  this.appendChild(c);c.addEventListener('animationend',()=>c.remove());
  vib([40]);setTimeout(launchApp,200);
});

/* ── WARDROBE ── */
wardrobeBtn.addEventListener('click',()=>{wardrobePanel.classList.toggle('open');vib([30]);});
closeWardBtn.addEventListener('click',()=>{wardrobePanel.classList.remove('open');vib([30]);});
const HG=['acc-tophat','acc-crown','acc-partyhat'];
const GG=['acc-chashma','acc-sunglasses'];
document.querySelectorAll('.acc-pick').forEach(pick=>{
  pick.addEventListener('click',()=>{
    const id=pick.dataset.acc,el=document.getElementById(id);if(!el)return;
    if(pick.classList.contains('active')){pick.classList.remove('active');el.classList.remove('worn');}
    else{
      if(HG.includes(id))HG.forEach(x=>{document.getElementById(x)?.classList.remove('worn');document.querySelector(`[data-acc="${x}"]`)?.classList.remove('active');});
      if(GG.includes(id))GG.forEach(x=>{document.getElementById(x)?.classList.remove('worn');document.querySelector(`[data-acc="${x}"]`)?.classList.remove('active');});
      pick.classList.add('active');el.classList.add('worn');
      el.style.animation='none';void el.offsetWidth;el.style.animation='';
      vib([30]);spawnPart(window.innerWidth/2,window.innerHeight*.22);
    }
  });
});

/* ── EXIT ── */
function showExit(){exitOverlay.classList.add('visible');}
function hideExit(){exitOverlay.classList.remove('visible');history.pushState({app:'main'},'');}
exitYes.addEventListener('click',()=>{exitOverlay.classList.remove('visible');mainScreen.classList.add('hidden');
  setTimeout(()=>{welcomeScreen.classList.remove('hidden');state=S.W;},300);});
exitNo.addEventListener('click',hideExit);
window.addEventListener('popstate',()=>{
  if(state===S.W)return;
  if(wardrobePanel.classList.contains('open')){wardrobePanel.classList.remove('open');history.pushState({app:'main'},'');return;}
  if(exitOverlay.classList.contains('visible'))hideExit();else showExit();
});
history.replaceState({app:'welcome'},'');

/* ── GESTURE PREVENTION ── */
document.addEventListener('touchmove',e=>e.preventDefault(),{passive:false});
document.addEventListener('contextmenu',e=>e.preventDefault());
let lT=0;
document.addEventListener('touchend',e=>{const n=Date.now();if(n-lT<300)e.preventDefault();lT=n;},{passive:false});
Object.values(VID).forEach(v=>v.addEventListener('error',()=>console.warn('Video:',v.src)));

})();
</script>
</body>
</html>
