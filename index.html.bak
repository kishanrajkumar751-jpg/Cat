<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<title>Talking Rabbit 🐰</title>
<style>
/* ============================================================
   RESET & BASE
============================================================ */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;
  -webkit-tap-highlight-color:transparent;touch-action:none;
  user-select:none;-webkit-user-select:none;}
html,body{width:100%;height:100%;overflow:hidden;
  font-family:'Comic Sans MS','Comic Sans','Chalkboard SE',cursive;background:#000;}

/* ============================================================
   KEYFRAMES
============================================================ */
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-18px)}}
@keyframes pulse-btn{
  0%,100%{transform:scale(1);box-shadow:0 0 0 0 rgba(255,105,180,.5),0 8px 30px rgba(255,20,147,.4)}
  50%{transform:scale(1.08);box-shadow:0 0 0 20px rgba(255,105,180,0),0 12px 40px rgba(255,20,147,.6)}}
@keyframes ripple{0%{transform:scale(0);opacity:.6}100%{transform:scale(4);opacity:0}}
@keyframes shake{
  0%{transform:translateX(0) rotate(0)}
  15%{transform:translateX(-8px) rotate(-2deg)}
  30%{transform:translateX(8px) rotate(2deg)}
  45%{transform:translateX(-6px) rotate(-1deg)}
  60%{transform:translateX(6px) rotate(1deg)}
  75%{transform:translateX(-3px)}
  100%{transform:translateX(0)}}
@keyframes particleFloat{
  0%{transform:translateY(0) scale(1);opacity:1}
  100%{transform:translateY(-120px) scale(.3);opacity:0}}
@keyframes fall{
  0%{top:-60px;opacity:1;transform:rotate(0) scale(1)}
  80%{opacity:1}
  100%{top:110%;opacity:0;transform:rotate(360deg) scale(.5)}}
@keyframes fadeVid{from{opacity:0}to{opacity:1}}
@keyframes recordPulse{
  0%,100%{box-shadow:0 0 0 0 rgba(239,68,68,.9),0 0 20px rgba(239,68,68,.6)}
  50%{box-shadow:0 0 0 20px rgba(239,68,68,0),0 0 40px rgba(239,68,68,1)}}
@keyframes listeningPulse{
  0%,100%{box-shadow:0 0 0 0 rgba(147,51,234,.8),0 0 20px rgba(147,51,234,.5)}
  50%{box-shadow:0 0 0 18px rgba(147,51,234,0),0 0 35px rgba(147,51,234,.9)}}
@keyframes speakingGlow{
  0%,100%{box-shadow:0 0 10px 4px rgba(253,224,71,.8),0 0 20px rgba(234,179,8,.5)}
  50%{box-shadow:0 0 26px 12px rgba(253,224,71,1),0 0 40px rgba(234,179,8,.9)}}
@keyframes dialogPop{
  0%{transform:scale(.7);opacity:0}
  70%{transform:scale(1.05)}
  100%{transform:scale(1);opacity:1}}
@keyframes wardrobePop{
  from{transform:translateY(100%);opacity:0}
  to{transform:translateY(0);opacity:1}}
@keyframes accOn{
  0%{transform:scale(0) rotate(-15deg);opacity:0}
  70%{transform:scale(1.1) rotate(3deg)}
  100%{transform:scale(1) rotate(0);opacity:1}}
@keyframes bounceIn{
  0%{transform:translateX(-50%) scale(.5);opacity:0}
  70%{transform:translateX(-50%) scale(1.1)}
  100%{transform:translateX(-50%) scale(1);opacity:1}}
@keyframes countdown{
  from{stroke-dashoffset:0}
  to{stroke-dashoffset:251}}
@keyframes bPop{
  0%{opacity:0;transform:translateX(-50%) scale(.55)}
  70%{transform:translateX(-50%) scale(1.06)}
  100%{opacity:1;transform:translateX(-50%) scale(1)}}
@keyframes bFade{
  to{opacity:0;transform:translateX(-50%) translateY(-12px) scale(.88)}}

/* ============================================================
   SCREENS
============================================================ */
.screen{position:fixed;inset:0;display:flex;flex-direction:column;
  align-items:center;justify-content:center;transition:opacity .5s ease;}
.screen.hidden{opacity:0;pointer-events:none;}

/* ============================================================
   WELCOME SCREEN
============================================================ */
#welcomeScreen{background:linear-gradient(135deg,#f093fb 0%,#f5576c 100%);z-index:10;}
.welcome-content{display:flex;flex-direction:column;align-items:center;gap:36px;padding:20px;}
#welcomeImg{width:90%;max-width:400px;border-radius:30px;
  border:8px solid rgba(255,255,255,.3);box-shadow:0 20px 60px rgba(0,0,0,.3);
  animation:float 3s ease-in-out infinite;object-fit:cover;}
#playBtn{
  position:relative;overflow:hidden;
  background:linear-gradient(180deg,#ff69b4,#ff1493);
  color:#fff;font-family:'Comic Sans MS','Comic Sans',cursive;
  font-size:32px;font-weight:bold;text-transform:uppercase;letter-spacing:2px;
  padding:18px 56px;border:none;border-radius:60px;cursor:pointer;
  border-bottom:5px solid #c71585;text-shadow:0 2px 4px rgba(0,0,0,.3);
  box-shadow:inset 0 2px 8px rgba(255,255,255,.45),
             inset 0 -3px 6px rgba(0,0,0,.15),
             0 8px 30px rgba(255,20,147,.4);
  animation:pulse-btn 2s ease-in-out infinite;}
#playBtn::before{content:'';position:absolute;inset:0;
  background:linear-gradient(180deg,rgba(255,255,255,.25) 0%,rgba(255,255,255,0) 60%);
  border-radius:60px;pointer-events:none;}
.ripple-circle{position:absolute;border-radius:50%;background:rgba(255,255,255,.5);
  width:60px;height:60px;transform:scale(0);animation:ripple .7s linear forwards;pointer-events:none;}

/* ============================================================
   MAIN SCREEN
============================================================ */
#mainScreen{background:linear-gradient(160deg,#a8edea 0%,#fed6e3 100%);z-index:5;}
.video-wrapper{position:absolute;inset:0;overflow:hidden;}
.rabbit-video{position:absolute;inset:0;width:100%;height:100%;
  object-fit:cover;object-position:center;opacity:0;transition:opacity .35s ease;}
.rabbit-video.active{opacity:1;animation:fadeVid .35s ease forwards;}

/* ============================================================
   CHARACTER FRAME — accessories anchor
============================================================ */
#characterFrame{
  position:absolute;left:50%;transform:translateX(-50%);
  top:0;bottom:0;width:min(55vw,280px);
  pointer-events:none;z-index:22;}
.acc-item{
  position:absolute;left:50%;transform:translateX(-50%);
  pointer-events:none;display:none;transform-origin:center top;}
.acc-item.worn{
  display:block;
  animation:accOn .4s cubic-bezier(.34,1.56,.64,1) forwards;}
#acc-chashma   {top:21%;width:96%;}
#acc-sunglasses{top:20%;width:100%;}
#acc-tophat    {top:-2%;width:72%;}
#acc-crown     {top:-4%;width:84%;}
#acc-bow       {top:39%;width:78%;}
#acc-scarf     {top:35%;width:115%;}
#acc-flower    {top:8%;left:82%;width:30%;}
#acc-partyhat  {top:-6%;width:52%;}

/* ============================================================
   TAP ZONES
============================================================ */
.tap-zone{position:absolute;cursor:pointer;z-index:20;}
#tapHead{top:8%;left:50%;transform:translateX(-50%);width:150px;height:150px;border-radius:50%;}
#tapBody{top:38%;left:50%;transform:translateX(-50%);width:180px;height:200px;border-radius:50%;}
#tapFeet{bottom:22%;left:50%;transform:translateX(-50%);width:200px;height:100px;border-radius:50%;}
.tap-zone.shake{animation:shake .5s ease;}

/* ============================================================
   STATUS BADGE
============================================================ */
#statusBadge{
  position:absolute;top:22px;left:50%;transform:translateX(-50%);
  background:linear-gradient(135deg,#8b5cf6,#6d28d9);
  color:#fff;font-family:'Comic Sans MS','Comic Sans',cursive;
  font-size:15px;font-weight:bold;padding:10px 24px;border-radius:50px;
  box-shadow:0 4px 16px rgba(109,40,217,.4);
  white-space:nowrap;z-index:30;opacity:0;pointer-events:none;transition:opacity .3s ease;}
#statusBadge.visible{opacity:1;animation:bounceIn .3s ease forwards;}

/* ============================================================
   CONTROL PANEL
============================================================ */
#controlPanel{
  position:absolute;bottom:38px;left:50%;transform:translateX(-50%);
  display:flex;align-items:center;gap:20px;z-index:30;}
.ctrl-btn{
  position:relative;overflow:hidden;border:none;cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  border-radius:50%;font-size:28px;
  transition:transform .15s ease;touch-action:none;flex-shrink:0;}
.ctrl-btn:active{transform:scale(.9);}
.ctrl-btn::before{content:'';position:absolute;top:0;left:0;right:0;height:50%;
  background:linear-gradient(180deg,rgba(255,255,255,.28) 0%,rgba(255,255,255,0) 100%);
  border-radius:50% 50% 0 0;pointer-events:none;}

#laughBtn{width:70px;height:70px;
  background:linear-gradient(180deg,#fbbf24,#f59e0b);border-bottom:5px solid #d97706;
  box-shadow:inset 0 2px 6px rgba(255,255,255,.4),0 6px 20px rgba(245,158,11,.5);}

#micBtn{width:88px;height:88px;
  background:linear-gradient(180deg,#ff69b4,#ff1493);
  border-bottom:6px solid #c71585;
  box-shadow:inset 0 2px 8px rgba(255,255,255,.4),0 8px 28px rgba(255,20,147,.5);}
#micBtn.recording{
  background:linear-gradient(180deg,#ef4444,#dc2626) !important;
  border-bottom-color:#b91c1c !important;
  animation:recordPulse .8s ease-in-out infinite !important;}
#micBtn.listening{
  background:linear-gradient(180deg,#a855f7,#7c3aed) !important;
  border-bottom-color:#5b21b6 !important;
  animation:listeningPulse 1s ease-in-out infinite !important;}
#micBtn.speaking{
  background:linear-gradient(180deg,#fde047,#eab308) !important;
  border-bottom-color:#a16207 !important;
  animation:speakingGlow 1s ease-in-out infinite !important;}

#musicBtn{width:70px;height:70px;
  background:linear-gradient(180deg,#a78bfa,#8b5cf6);border-bottom:5px solid #6d28d9;
  box-shadow:inset 0 2px 6px rgba(255,255,255,.35),0 6px 20px rgba(139,92,246,.5);}
#wardrobeBtn{width:70px;height:70px;font-size:32px;
  background:linear-gradient(180deg,#34d399,#059669);border-bottom:5px solid #047857;
  box-shadow:inset 0 2px 6px rgba(255,255,255,.35),0 6px 20px rgba(5,150,105,.5);}

/* Mic icon */
.mic-icon{position:relative;width:26px;height:38px;pointer-events:none;}
.mic-icon::before{content:'';position:absolute;top:0;left:50%;transform:translateX(-50%);
  width:18px;height:24px;background:#fff;border-radius:9px;}
.mic-icon::after{content:'';position:absolute;bottom:0;left:50%;transform:translateX(-50%);
  width:2px;height:7px;background:#fff;border-radius:2px;}
.mic-arc{position:absolute;bottom:5px;left:50%;transform:translateX(-50%);
  width:26px;height:15px;border:3px solid #fff;border-top:none;border-radius:0 0 18px 18px;}

/* Mic label */
#micLabel{position:absolute;bottom:-22px;left:50%;transform:translateX(-50%);
  color:#fff;font-size:11px;font-weight:bold;white-space:nowrap;
  text-shadow:0 1px 4px rgba(0,0,0,.6);pointer-events:none;}

/* Countdown ring */
#recRing{position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:1;}
#recRing circle{fill:none;stroke:rgba(255,255,255,0);stroke-width:5;
  stroke-dasharray:251;stroke-dashoffset:251;
  stroke-linecap:round;transform-origin:center;transform:rotate(-90deg);}
#recRing.running circle{
  stroke:rgba(255,255,255,0.85);stroke-dashoffset:0;
  animation:countdown 5s linear forwards;}

/* Chat bubble */
#chatBubble{
  position:fixed;bottom:185px;left:50%;
  background:linear-gradient(135deg,#fffde7,#fff8e1);
  color:#222;font-family:'Comic Sans MS','Comic Sans',cursive;
  font-size:15px;font-weight:bold;padding:13px 20px 18px;
  border-radius:22px;border:3px solid #ffd700;
  box-shadow:0 6px 24px rgba(0,0,0,.22);
  max-width:270px;text-align:center;z-index:60;
  word-wrap:break-word;line-height:1.5;pointer-events:none;
  animation:bPop .35s cubic-bezier(.34,1.56,.64,1) forwards;}

/* Chat input */
#chatWrap{
  position:fixed;bottom:158px;left:50%;transform:translateX(-50%);
  display:flex;gap:8px;z-index:40;align-items:center;}
#chatInput{
  width:192px;padding:10px 16px;border-radius:40px;
  border:3px solid #ff69b4;
  font-family:'Comic Sans MS','Comic Sans',cursive;
  font-size:13px;outline:none;
  box-shadow:0 3px 10px rgba(255,105,180,.3);
  background:rgba(255,255,255,.95);
  touch-action:auto;user-select:text;-webkit-user-select:text;}
#chatSendBtn{
  width:44px;height:44px;border-radius:50%;border:none;
  background:linear-gradient(180deg,#ff69b4,#ff1493);
  font-size:20px;cursor:pointer;
  box-shadow:0 3px 10px rgba(255,20,147,.4);
  flex-shrink:0;touch-action:none;border-bottom:3px solid #c71585;}

/* ============================================================
   WARDROBE PANEL
============================================================ */
#wardrobePanel{
  position:fixed;bottom:0;left:0;right:0;
  background:linear-gradient(180deg,#fdf4ff,#fce7f3);
  border-radius:28px 28px 0 0;box-shadow:0 -8px 40px rgba(0,0,0,.25);
  z-index:50;padding:14px 12px 28px;display:none;}
#wardrobePanel.open{display:block;animation:wardrobePop .35s cubic-bezier(.34,1.56,.64,1) forwards;}
.wd-handle{width:48px;height:5px;background:#d1d5db;border-radius:10px;margin:0 auto 12px;}
.wd-title{text-align:center;font-size:17px;font-weight:bold;color:#7c3aed;margin-bottom:12px;}
.wd-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;}
.acc-pick{display:flex;flex-direction:column;align-items:center;gap:4px;
  background:#fff;border-radius:14px;padding:9px 4px;border:3px solid transparent;
  cursor:pointer;transition:all .2s ease;box-shadow:0 2px 8px rgba(0,0,0,.08);touch-action:none;}
.acc-pick.active{border-color:#8b5cf6;background:linear-gradient(135deg,#f5f3ff,#ede9fe);
  box-shadow:0 4px 14px rgba(139,92,246,.35);}
.acc-pick svg{width:44px;height:44px;}
.acc-pick span{font-size:10px;font-weight:bold;color:#6d28d9;text-align:center;}
.acc-pick .ae{font-size:32px;line-height:1;}
.wd-bottom{display:flex;justify-content:center;margin-top:12px;}
#closeWardrobeBtn{background:linear-gradient(180deg,#f87171,#ef4444);color:#fff;border:none;
  border-radius:40px;font-family:'Comic Sans MS',cursive;font-size:15px;font-weight:bold;
  padding:10px 30px;cursor:pointer;border-bottom:4px solid #dc2626;
  box-shadow:0 4px 14px rgba(239,68,68,.4);touch-action:none;}

/* ============================================================
   PARTICLES
============================================================ */
.particle{position:fixed;font-size:28px;pointer-events:none;z-index:999;
  animation:particleFloat 1.5s ease-out forwards;}
.falling-emoji{position:fixed;font-size:32px;pointer-events:none;z-index:999;
  animation:fall 4s ease-in forwards;left:0;top:-60px;}

/* ============================================================
   EXIT DIALOG
============================================================ */
#exitOverlay{position:fixed;inset:0;background:rgba(0,0,0,.8);z-index:100;
  display:flex;align-items:center;justify-content:center;
  opacity:0;pointer-events:none;transition:opacity .3s ease;}
#exitOverlay.visible{opacity:1;pointer-events:all;}
#exitDialog{background:linear-gradient(145deg,#8b5cf6,#6d28d9);border-radius:28px;
  padding:36px 32px 28px;text-align:center;width:min(320px,85vw);
  box-shadow:0 24px 60px rgba(0,0,0,.5);
  animation:dialogPop .4s cubic-bezier(.34,1.56,.64,1) forwards;}
#exitDialog p{color:#fff;font-size:22px;font-weight:bold;margin-bottom:28px;
  text-shadow:0 2px 4px rgba(0,0,0,.3);}
.exit-btns{display:flex;gap:16px;justify-content:center;}
.exit-btn{flex:1;padding:14px 10px;border:none;border-radius:50px;
  font-family:'Comic Sans MS',cursive;font-size:18px;font-weight:bold;
  cursor:pointer;transition:transform .15s ease;touch-action:none;}
.exit-btn:active{transform:scale(.93);}
#exitYes{background:linear-gradient(180deg,#ff69b4,#ff1493);color:#fff;
  border-bottom:4px solid #c71585;box-shadow:0 4px 14px rgba(255,20,147,.5);}
#exitNo{background:linear-gradient(180deg,#22d3ee,#06b6d4);color:#fff;
  border-bottom:4px solid #0891b2;box-shadow:0 4px 14px rgba(6,182,212,.5);}

/* ============================================================
   RESPONSIVE
============================================================ */
@media(max-width:600px){
  #controlPanel{gap:14px;bottom:24px;}
  #laughBtn,#musicBtn,#wardrobeBtn{width:62px;height:62px;}
  #micBtn{width:78px;height:78px;}
  .ctrl-btn{font-size:24px;}
  #welcomeImg{max-width:320px;}
  #playBtn{font-size:26px;padding:15px 44px;}
  #characterFrame{width:min(58vw,260px);}
}
@media(max-width:400px){
  #controlPanel{gap:10px;bottom:18px;}
  #laughBtn,#musicBtn,#wardrobeBtn{width:55px;height:55px;font-size:21px;}
  #micBtn{width:68px;height:68px;}
  #welcomeImg{max-width:280px;}
  #playBtn{font-size:21px;padding:12px 34px;}
  #characterFrame{width:min(62vw,220px);}
}
</style>
</head>
<body>

<!-- ============================================================
     WELCOME SCREEN
============================================================ -->
<div id="welcomeScreen" class="screen">
  <div class="welcome-content">
    <img id="welcomeImg" src="tom_welcome.jpg" alt="Talking Rabbit">
    <button id="playBtn">▶ Play</button>
  </div>
</div>

<!-- ============================================================
     MAIN SCREEN
============================================================ -->
<div id="mainScreen" class="screen hidden">

  <!-- Videos -->
  <div class="video-wrapper">
    <video id="vidStanding"  class="rabbit-video active" src="tom_standing.mp4"  autoplay loop muted playsinline preload="auto"></video>
    <video id="vidListening" class="rabbit-video"        src="tom_listing.mp4"         muted playsinline preload="auto"></video>
    <video id="vidTalking"   class="rabbit-video"        src="tom_talking.mp4"          muted playsinline preload="auto"></video>
    <video id="vidLaughing"  class="rabbit-video"        src="laughing.mp4"             muted playsinline preload="auto"></video>
    <video id="vidMusic"     class="rabbit-video"        src="music.mp4"                muted playsinline preload="auto"></video>
  </div>

  <!-- ── ACCESSORIES ── -->
  <div id="characterFrame">
    <div id="acc-chashma" class="acc-item">
      <svg viewBox="0 0 200 62" fill="none"><line x1="0" y1="26" x2="28" y2="28" stroke="#3b1f00" stroke-width="4.5" stroke-linecap="round"/><line x1="172" y1="28" x2="200" y2="26" stroke="#3b1f00" stroke-width="4.5" stroke-linecap="round"/><ellipse cx="52" cy="31" rx="38" ry="26" fill="rgba(135,206,235,0.42)" stroke="#3b1f00" stroke-width="5"/><ellipse cx="148" cy="31" rx="38" ry="26" fill="rgba(135,206,235,0.42)" stroke="#3b1f00" stroke-width="5"/><path d="M90 31 Q100 25 110 31" stroke="#3b1f00" stroke-width="4.5" fill="none" stroke-linecap="round"/><ellipse cx="36" cy="22" rx="9" ry="6" fill="rgba(255,255,255,0.55)" transform="rotate(-20 36 22)"/><ellipse cx="132" cy="22" rx="9" ry="6" fill="rgba(255,255,255,0.55)" transform="rotate(-20 132 22)"/></svg>
    </div>
    <div id="acc-sunglasses" class="acc-item">
      <svg viewBox="0 0 210 66" fill="none"><line x1="0" y1="28" x2="28" y2="30" stroke="#111" stroke-width="5" stroke-linecap="round"/><line x1="182" y1="30" x2="210" y2="28" stroke="#111" stroke-width="5" stroke-linecap="round"/><rect x="28" y="10" width="68" height="46" rx="14" fill="rgba(15,15,15,0.88)" stroke="#111" stroke-width="5"/><rect x="114" y="10" width="68" height="46" rx="14" fill="rgba(15,15,15,0.88)" stroke="#111" stroke-width="5"/><path d="M96 33 Q105 27 114 33" stroke="#111" stroke-width="5" fill="none" stroke-linecap="round"/><rect x="34" y="17" width="22" height="10" rx="6" fill="rgba(255,255,255,0.28)" transform="rotate(-8 34 17)"/><rect x="120" y="17" width="22" height="10" rx="6" fill="rgba(255,255,255,0.28)" transform="rotate(-8 120 17)"/></svg>
    </div>
    <div id="acc-tophat" class="acc-item">
      <svg viewBox="0 0 160 130" fill="none"><ellipse cx="80" cy="108" rx="72" ry="18" fill="#1a1a1a" stroke="#000" stroke-width="2"/><rect x="28" y="16" width="104" height="94" rx="10" fill="#1a1a1a" stroke="#000" stroke-width="2"/><rect x="28" y="88" width="104" height="16" rx="5" fill="#ff1493"/><circle cx="80" cy="96" r="7" fill="#ffd700"/><ellipse cx="55" cy="36" rx="14" ry="8" fill="rgba(255,255,255,0.10)" transform="rotate(-10 55 36)"/></svg>
    </div>
    <div id="acc-crown" class="acc-item">
      <svg viewBox="0 0 180 100" fill="none"><path d="M12 90 L12 50 L46 72 L90 8 L134 72 L168 50 L168 90 Z" fill="#FFD700" stroke="#d4a000" stroke-width="3" stroke-linejoin="round"/><rect x="12" y="78" width="156" height="18" rx="7" fill="#d4a000"/><circle cx="90" cy="84" r="10" fill="#ff1493" stroke="#c71585" stroke-width="2"/><circle cx="46" cy="84" r="8" fill="#22d3ee" stroke="#0891b2" stroke-width="2"/><circle cx="134" cy="84" r="8" fill="#a78bfa" stroke="#6d28d9" stroke-width="2"/><circle cx="90" cy="11" r="9" fill="#FFE066" stroke="#d4a000" stroke-width="2"/><circle cx="13" cy="52" r="7" fill="#FFE066" stroke="#d4a000" stroke-width="2"/><circle cx="167" cy="52" r="7" fill="#FFE066" stroke="#d4a000" stroke-width="2"/></svg>
    </div>
    <div id="acc-bow" class="acc-item">
      <svg viewBox="0 0 140 68" fill="none"><path d="M66 34 L8 8 L8 60 Z" fill="#ff1493" stroke="#c71585" stroke-width="3" stroke-linejoin="round"/><path d="M74 34 L132 8 L132 60 Z" fill="#ff1493" stroke="#c71585" stroke-width="3" stroke-linejoin="round"/><ellipse cx="70" cy="34" rx="16" ry="20" fill="#ffd700" stroke="#d4a000" stroke-width="3"/><ellipse cx="30" cy="24" rx="10" ry="6" fill="rgba(255,255,255,0.30)" transform="rotate(30 30 24)"/><ellipse cx="110" cy="24" rx="10" ry="6" fill="rgba(255,255,255,0.30)" transform="rotate(-30 110 24)"/></svg>
    </div>
    <div id="acc-scarf" class="acc-item">
