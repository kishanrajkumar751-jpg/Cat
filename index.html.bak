    data-messages='["My feet! Hehe!","Stop it! Haha!","Ha ha ha!","Tickle tickle! 😝","Oohh hehe! 🐾"]'></div>

  <!-- Status Badge -->
  <div id="statusBadge"></div>

  <!-- Chat Input -->
  <div id="chatWrap">
